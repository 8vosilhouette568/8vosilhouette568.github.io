{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": false,
    "declaration": true,
    "outDir": "./",
    "rootDir": "./",
    "baseUrl": ".",
    "paths": {
      "@libs/*": ["./libs/*"],
      "@/types/*": ["./types/*"],
      "@/*": ["./*"]
    },
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true
  },
  "include": ["rncalation.ts"],
  "exclude": ["node_modules"]
}
