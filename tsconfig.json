{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": false,
    "baseUrl": ".",
    "paths": {
      "@libs/*": ["libs/*"],
      "@/types/*": ["types/*"],
      "@/*": ["*"]
    },
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "noEmitOnError": false
  },
  "include": ["src/spanish/rncalation/rncalation.ts", "libs/**/*", "types/**/*"],
  "exclude": ["node_modules"]
}